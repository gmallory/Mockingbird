{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "--directory", "frontend", "uvicorn", "app.main:app", "--port", "3002"],
      "port": 3002
    },
    {
      "name": "gateway",
      "runtimeExecutable": "bash",
      "runtimeArgs": [
        "-lc",
        "SUPABASE_JWT_SECRET=dev-jwt-secret-for-local-verification-000 uv run --directory gateway uvicorn app.main:app --port 3001"
      ],
      "port": 3001
    }
  ]
}
