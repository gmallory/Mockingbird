# Gateway — echo-slice settings. Copy to .env to override defaults.
HOST=0.0.0.0
PORT=3001
# JSON array of allowed origins. Defaults to the local dev frontend; set this
# explicitly for any other deployment. Never use ["*"] outside a dev box.
ALLOWED_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]
# Inference service targets (gRPC for the hot path, HTTP for voice cloning).
INFERENCE_GRPC_URL=localhost:50051
INFERENCE_SERVICE_URL=http://localhost:8001
