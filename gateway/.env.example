# Gateway — echo-slice settings. Copy to .env to override defaults.
HOST=0.0.0.0
PORT=3001
# JSON array of allowed origins, or ["*"] for local dev.
ALLOWED_ORIGINS=["*"]
# Inference service targets (gRPC for the hot path, HTTP for voice cloning).
INFERENCE_GRPC_URL=localhost:50051
INFERENCE_SERVICE_URL=http://localhost:8001
