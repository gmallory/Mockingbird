# =============================================================================
# Mockingbird — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# === DATABASE ===
DATABASE_URL=postgresql://mockingbird:dev_password@localhost:5432/mockingbird

# === REDIS ===
REDIS_URL=redis://localhost:6379

# === HD TRAINING (M9 — Celery + Redis job queue) ===
# POST /api/voices/:id/train enqueues a Celery task (gateway/app/training/).
# Empty -> reuse REDIS_URL above for both broker and result backend (the
# common case; only set these to point training at a different Redis
# instance). Run a worker with: celery -A app.training.celery_app worker
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
# Tests set this true to run the training task synchronously in-process with
# no live worker/broker (Celery "eager" mode). Leave false in production.
CELERY_TASK_ALWAYS_EAGER=false

# === AUTH (M6a — Supabase-hosted) ===
# The gateway proxies signup/login to Supabase (GoTrue) and *verifies* the
# access token it returns. SUPABASE_URL + SUPABASE_ANON_KEY drive the proxy;
# SUPABASE_JWT_SECRET is the project's symmetric JWT secret (Supabase dashboard →
# Project Settings → API → JWT Secret), used to verify HS256 tokens offline.
# For local dev without a Supabase project you can still exercise verification by
# setting SUPABASE_JWT_SECRET to any value and minting HS256 tokens with it (see
# gateway/tests/test_auth.py::_mint); only the signup/login proxy needs the URL.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-project-jwt-secret-hs256
# Reserved for the alternative self-issued-JWT path (not used in Supabase mode).
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
# Realtime socket auth (M6b). /ws/voice reads its token from a ?token=<jwt> query
# param. Off by default: no token -> anonymous echo-only demo. Set true to reject
# tokenless connections (WS close 4001); an invalid token is rejected either way.
WS_REQUIRE_AUTH=false

# === TWILIO (Phone Calling, M8a) ===
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890
# Public https base URL Twilio can reach for the status callback and the
# media-stream WebSocket — in dev, a tunnel to the gateway (port 3001), e.g.
# `ngrok http 3001` or `cloudflared tunnel --url http://localhost:3001`.
# Unset -> POST /api/calls/outbound returns 503; everything else still works.
PUBLIC_BASE_URL=

# === STORAGE (S3 / MinIO) ===
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=mockingbird-models
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# === INFERENCE SERVICE ===
INFERENCE_SERVICE_URL=http://localhost:8001
# For cloud_gpu deploys, point this at the rented GPU box's gRPC endpoint
# (that box runs the same inference service with INFERENCE_BACKEND=cloud_gpu).
INFERENCE_GRPC_URL=localhost:50051
DEVICE=auto  # 'auto' (CUDA > CoreML > CPU), 'cuda', 'coreml', or 'cpu'

# === INFERENCE BACKEND (mode selection) ===
# self_hosted (primary) | cloud_gpu (same stack on a rented GPU) | cartesia | elevenlabs
INFERENCE_BACKEND=self_hosted
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=

# === SELF-HOSTED / CLOUD_GPU BACKEND ===
# Local directory of {model_id}.onnx voice models; missing models are fetched
# from s3://$S3_BUCKET/models/{model_id}.onnx when S3_BUCKET is set.
SELF_HOSTED_MODEL_DIR=models
SELF_HOSTED_DEFAULT_MODEL=
# OpenVoice V2 models (the M5b export) run at 22050; set 48000 only for models
# that natively take 48kHz audio.
SELF_HOSTED_MODEL_SAMPLE_RATE=22050
# Tuned on real OpenVoice weights (M5b): 60ms blocks + 140ms context ≈ 107ms
# effective added latency at real-time factor <1 on an M-series CPU. The
# context+block window drives compute — don't raise context without re-running
# scripts/self_hosted_bench.py.
SELF_HOSTED_BLOCK_MS=60
SELF_HOSTED_CONTEXT_MS=140
# Held-back tail blended with the next block's re-rendering at each seam; adds
# this much latency. 0 disables.
SELF_HOSTED_CROSSFADE_MS=5
SELF_HOSTED_MAX_LOADED_MODELS=4

# === FEATURE FLAGS ===
ENABLE_CALLING=true
ENABLE_RECORDING=false
ENABLE_TRAINING=true

# === MONITORING ===
SENTRY_DSN=
PROMETHEUS_PORT=9090

# === FRONTEND (PUBLIC_ prefix = rendered into pages, safe to expose to the browser) ===
PUBLIC_API_URL=http://localhost:3001
PUBLIC_WS_URL=ws://localhost:3001/ws/voice
